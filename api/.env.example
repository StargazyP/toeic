PORT=4000
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=toeic
DB_PASS=your_password_here
DB_NAME=toeic
JWT_SECRET=your_jwt_secret_here

# Ollama (로컬 LLM)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=phi3:mini
# 영문->한글 번역용 (비우면 phi3가 직접 한글 생성, 설정하면 qwen2로 재번역)
# OLLAMA_TRANSLATION_MODEL=qwen2:1.5b

# OpenAI (Ollama 실패 시 fallback)
# OPENAI_API_KEY=your_openai_api_key_here
