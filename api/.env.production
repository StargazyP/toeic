# ============================================================
# 프로덕션 환경변수 템플릿
# 사용법: 이 파일을 복사하여 .env로 저장하고 값을 채워주세요
#   cp .env.production .env
# ============================================================

PORT=4000

# ── Database ──
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=toeic
DB_PASS=__CHANGE_ME__
DB_NAME=toeic

# ── Auth ──
# 반드시 변경! openssl rand -base64 32 로 생성
JWT_SECRET=__CHANGE_ME__

# ── Ollama (로컬 LLM) ──
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=phi3:mini
OLLAMA_TRANSLATION_MODEL=qwen2:1.5b

# ── OpenAI (Ollama 실패 시 fallback, 선택사항) ──
# OPENAI_API_KEY=sk-...

# ── Auto Scaler ──
AI_CONCURRENCY=5
